    {
      "parameters": {
        "jsCode": "// Extract raw LLM response supporting multiple providers (OpenAI, Gemini, etc.)\nconst input = $input.first().json;\n\nconst raw =\n  input.message?.content ||              // OpenAI\n  input.text ||                          // Generic fallback\n  input.content?.parts?.[0]?.text ||     // Gemini (IMPORTANT)\n  '';\n\n// Get validated ticket data from previous step\nconst ticketData = $('Validate - Payload Structure').first().json;\n\n// Allowed values\nconst TIPOS_VALIDOS = ['Bug', 'Dúvida', 'Problema operacional'];\nconst SEVERIDADES_VALIDAS = ['Alta', 'Média', 'Baixa'];\nconst TIMES_VALIDOS = ['Produto', 'Engenharia', 'Operações'];\n\nlet parsed;\n\ntry {\n  // Extract JSON even if surrounded by text\n  const jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n\n  if (!jsonMatch) {\n    throw new Error('No JSON found in LLM response');\n  }\n\n  parsed = JSON.parse(jsonMatch[0]);\n\n} catch (e) {\n  return [{\n    json: {\n      parse_error: true,\n      error: `LLM parsing failed: ${e.message}`,\n      raw_response: raw,\n      ticket_id: ticketData.ticket_id,\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\n// Validation\nconst errors = [];\n\nif (!TIPOS_VALIDOS.includes(parsed.tipo)) {\n  errors.push(`invalid tipo: \"${parsed.tipo}\"`);\n}\n\nif (!SEVERIDADES_VALIDAS.includes(parsed.severidade)) {\n  errors.push(`invalid severidade: \"${parsed.severidade}\"`);\n}\n\nif (!TIMES_VALIDOS.includes(parsed.time_responsavel)) {\n  errors.push(`invalid time_responsavel: \"${parsed.time_responsavel}\"`);\n}\n\nif (errors.length > 0) {\n  return [{\n    json: {\n      parse_error: true,\n      error: `Values out of allowed range: ${errors.join(', ')}`,\n      raw_response: raw,\n      ticket_id: ticketData.ticket_id,\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\n// Success\nreturn [{\n  json: {\n    parse_error: false,\n    ticket_id: ticketData.ticket_id,\n    titulo: ticketData.titulo,\n    descricao: ticketData.descricao,\n    solicitante: ticketData.solicitante,\n    criado_em: ticketData.criado_em,\n    tipo: parsed.tipo,\n    severidade: parsed.severidade,\n    time_responsavel: parsed.time_responsavel,\n    completo: parsed.completo !== false,\n    motivo_incompleto: parsed.motivo_incompleto || null,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
