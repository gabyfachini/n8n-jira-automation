      "parameters": {
        "jsCode": "// Get input data\nconst d = $input.first().json;\n\n// Build row for Google Sheets\nreturn [{\n  json: {\n    dados_execucao: d.timestamp,\n    ticket_id: d.ticket_id,\n    titulo: d.titulo,\n    descricao: d.descricao,\n    solicitante: d.solicitante,\n    tipo: d.tipo,\n    gravidade: d.severidade,\n    tempo_responsavel: d.time_responsavel,\n\n    // Status based on parsing result\n    status: d.parse_error ? 'erro' : 'sucesso',\n\n    // Error or incomplete reason\n    motivo: d.motivo_incompleto || d.error || '',\n\n    // Raw LLM response (if available)\n    raw_llm: d.raw_response || ''\n  }\n}];"
      },
