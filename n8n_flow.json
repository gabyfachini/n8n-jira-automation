    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst fallbackId = `JIRA-ERR-${Date.now()}-${Math.random().toString(36).substring(2,6).toUpperCase()}`;\n\nconst requiredFields = ['ticket_id', 'titulo', 'descricao', 'solicitante'];\n\nconst missing = [];\nconst empty = [];\n\nfor (const field of requiredFields) {\n  if (!(field in body)) {\n    missing.push(field);\n  } else if (!body[field] || String(body[field]).trim() === '') {\n    empty.push(field);\n  }\n}\n\nif (missing.length > 0 || empty.length > 0) {\n  const errorMsg = [\n    missing.length > 0 ? `Missing fields: ${missing.join(', ')}` : '',\n    empty.length > 0 ? `Empty fields: ${empty.join(', ')}` : ''\n  ]\n  .filter(Boolean)\n  .join(' | ');\n\n  return [{\n    json: {\n      valid: false,\n      error: errorMsg,\n      ticket_id: body.ticket_id || fallbackId,\n      titulo: body.titulo || '',\n      descricao: body.descricao || '',\n      solicitante: body.solicitante || '',\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nif (!body.descricao || body.descricao.trim().length < 20) {\n  return [{\n    json: {\n      valid: false,\n      error: 'description too short for reliable classification (minimum 20 characters)',\n      ticket_id: body.ticket_id || fallbackId,\n      titulo: body.titulo || '',\n      descricao: body.descricao || '',\n      solicitante: body.solicitante || '',\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    ticket_id: body.ticket_id,\n    titulo: body.titulo.trim(),\n    descricao: body.descricao.trim(),\n    solicitante: body.solicitante.trim(),\n    criado_em: body.criado_em || new Date().toISOString()\n  }\n}];"
      },
