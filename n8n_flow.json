    {
      "parameters": {
        "jsCode": "const err = $input.first().json;\n\n// Estruturas seguras\nconst execution = err.execution || {};\nconst workflow = err.workflow || {};\nconst node = err.node || {};\n\n// 🔥 Função para gerar ID único estilo JIRA\nfunction generateTicketId() {\n  const timestamp = Date.now();\n  const random = Math.random().toString(36).substring(2, 6).toUpperCase();\n  return `JIRA-ERR-${timestamp}-${random}`;\n}\n\n// 🔍 Tenta recuperar ticket_id do fluxo\nlet ticketId = null;\n\ntry {\n  ticketId =\n    err.execution?.data?.resultData?.runData?.[\"Valida Payload\"]?.[0]?.data?.main?.[0]?.[0]?.json?.ticket_id\n    || null;\n} catch (e) {\n  ticketId = null;\n}\n\n// 🔒 Garante ID único\nif (!ticketId || ticketId === \"UNKNOWN\" || ticketId.trim() === \"\") {\n  ticketId = generateTicketId();\n}\n\n// 🔥 Classificação do erro\nconst errorMessage = execution.error?.message || \"\";\n\nlet tipoErro = \"TECNICO\";\n\nif (errorMessage.toLowerCase().includes(\"timeout\")) {\n  tipoErro = \"TIMEOUT\";\n} else if (errorMessage.toLowerCase().includes(\"credential\")) {\n  tipoErro = \"CREDENCIAL\";\n} else if (errorMessage.toLowerCase().includes(\"network\")) {\n  tipoErro = \"REDE\";\n}\n\n// 🔁 Retry inteligente\nconst retry = [\"TIMEOUT\", \"REDE\"].includes(tipoErro);\n\n// 📦 Retorno final\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n\n    workflow: workflow.name || \"UNKNOWN\",\n    execution_id: execution.id || \"UNKNOWN\",\n\n    node: node.name || \"UNKNOWN\",\n\n    error_message: errorMessage || \"Erro desconhecido\",\n    error_stack: execution.error?.stack || \"\",\n\n    ticket_id: ticketId,\n\n    step: node.name || \"UNKNOWN\",\n\n    payload_input: JSON.stringify(err.execution?.data || {}),\n\n    tipo_erro: tipoErro,\n    retry: retry\n  }\n}];"
      },
