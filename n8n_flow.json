        "html": "=<div style=\"font-family: Arial, sans-serif; background-color:#f4f6f8; padding:20px;\">\n  \n  <div style=\"max-width:600px; margin:auto; background:#ffffff; border-radius:8px; padding:20px;\">\n    \n    <h2 style=\"color:#d32f2f;\">🚨 Erro Global no Fluxo</h2>\n\n    <p><strong>Workflow:</strong> {{$json.workflow}}</p>\n    <p><strong>Execução:</strong> {{$json.execution_id}}</p>\n    <p><strong>Node:</strong> {{$json.node}}</p>\n\n    <hr/>\n\n    <p><strong>📌 Ticket ID:</strong> {{$json.ticket_id}}</p>\n    <p><strong>⚙️ Etapa:</strong> {{$json.step}}</p>\n    <p><strong>📅 Data:</strong> {{$json.timestamp}}</p>\n\n    <hr/>\n\n    <p><strong>❌ Tipo de Erro:</strong> {{$json.tipo_erro}}</p>\n    <p><strong>🔁 Retry:</strong> {{$json.retry}}</p>\n\n    <div style=\"margin-top:15px;\">\n      <strong>🧠 Mensagem:</strong>\n      <pre style=\"background:#f8f8f8; padding:10px; border-radius:5px;\">\n{{$json.error_message}}\n      </pre>\n    </div>\n\n    <div style=\"margin-top:15px;\">\n      <strong>📚 Stack:</strong>\n      <pre style=\"background:#f8f8f8; padding:10px; border-radius:5px; max-height:200px; overflow:auto;\">\n{{$json.error_stack}}\n      </pre>\n    </div>\n\n  </div>\n\n</div>",
